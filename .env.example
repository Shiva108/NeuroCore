# Copy this file to .env for local development.
# Never commit real credentials, production URLs, or operator-specific values.
# This template is query-ready by default. Report generation stays disabled until
# you add local-only consensus provider values below.

NEUROCORE_DEFAULT_NAMESPACE=default
NEUROCORE_ALLOWED_BUCKETS=work,research,planning,personal,ops
NEUROCORE_DEFAULT_SENSITIVITY=standard
NEUROCORE_STORAGE_BACKEND=in_memory
NEUROCORE_PRIMARY_STORE_PATH=neurocore.db
NEUROCORE_SEALED_STORE_PATH=neurocore.sealed.db
NEUROCORE_SEMANTIC_BACKEND=none
NEUROCORE_SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
NEUROCORE_MAX_ATOMIC_TOKENS=350
NEUROCORE_TARGET_CHUNK_TOKENS=600
NEUROCORE_MAX_CHUNK_TOKENS=900
NEUROCORE_CHUNK_OVERLAP_TOKENS=75
NEUROCORE_MAX_CONTENT_TOKENS=50000
NEUROCORE_DEFAULT_TOP_K=8
NEUROCORE_ALLOW_HARD_DELETE=false
NEUROCORE_ENABLE_ADMIN_SURFACE=false
NEUROCORE_ENABLE_CLI_ADAPTER=true
NEUROCORE_ENABLE_HTTP_ADAPTER=false
NEUROCORE_ENABLE_MCP_ADAPTER=false
NEUROCORE_ENABLE_DASHBOARD=false
NEUROCORE_ENABLE_BACKGROUND_SUMMARIZATION=false
NEUROCORE_ENABLE_MULTI_MODEL_CONSENSUS=false
NEUROCORE_CONSENSUS_PROVIDER=none
NEUROCORE_CONSENSUS_MODEL_NAMES=
NEUROCORE_CONSENSUS_BASE_URL=
NEUROCORE_CONSENSUS_API_KEY=
# For full local report generation, switch to:
# NEUROCORE_ENABLE_MULTI_MODEL_CONSENSUS=true
# NEUROCORE_CONSENSUS_PROVIDER=openai_compatible
# NEUROCORE_CONSENSUS_MODEL_NAMES=model-a,model-b
# NEUROCORE_CONSENSUS_BASE_URL=http://127.0.0.1:8787/v1
# NEUROCORE_CONSENSUS_API_KEY=local-dev-key
NEUROCORE_PRODUCTION_BACKEND_PROVIDER=none
NEUROCORE_PRODUCTION_DATABASE_URL=
NEUROCORE_PRODUCTION_SEALED_DATABASE_URL=
NEUROCORE_DEDUP_MERGE_METADATA=true
